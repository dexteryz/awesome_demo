{
  "app": {
    "name": "Demo Todo App (fixture)",
    "baseUrl": "http://localhost:4000",
    "startPath": "/",
    "viewport": { "width": 1280, "height": 720 }
  },
  "auth": {
    "seedSteps": [],
    "envVars": []
  },
  "models": {
    "prAnalysis": { "model": "claude-opus-4-8", "maxTokens": 4096 },
    "browserAgent": { "model": "claude-sonnet-4-6", "maxTokens": 1024 }
  },
  "capture": {
    "maxRetriesPerStep": 3,
    "maxTurnsPerStep": 12,
    "headless": true,
    "video": { "width": 1280, "height": 720 },
    "fallbackStepDurationSec": 3,
    "pace": {
      "enabled": true,
      "prerollSec": 0.5,
      "holdSec": 1.4,
      "gapMergeSec": 0.4,
      "minStepDurationSec": 2.5
    }
  },
  "output": {
    "runsDir": "./runs"
  },
  "hyperframes": {
    "outputFile": "demo.mp4",
    "hideCaptionsWhenNarrated": false
  },
  "narration": {
    "enabled": false,
    "provider": "elevenlabs",
    "voiceId": "${ELEVENLABS_VOICE_ID}",
    "modelId": "eleven_multilingual_v2",
    "pronunciations": [
      { "from": "Todos", "to": "to-do's" },
      { "from": "todo", "to": "to-do" }
    ]
  },
  "github": {
    "repo": null
  }
}
