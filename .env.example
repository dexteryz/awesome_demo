# Required for PR analysis + browser capture agent (Claude API calls)
ANTHROPIC_API_KEY=

# Referenced by demo-gen.config.json's auth.envVars for logging into the target app.
# Never commit real values here.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Required only when narration.enabled is true (voice-over via ElevenLabs).
# Set narration.voiceId in demo-gen.config.json to your cloned or stock voice id.
ELEVENLABS_API_KEY=
