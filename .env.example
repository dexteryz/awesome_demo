# Required for PR analysis + browser capture agent (Claude API calls)
ANTHROPIC_API_KEY=

# Referenced by demo-gen.config.json's auth.envVars for logging into the target app.
# Never commit real values here.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Voice-over via ElevenLabs. The key is a secret; the voice id is referenced from
# demo-gen.config.json as ${ELEVENLABS_VOICE_ID}. Turn narration on/off in the config
# (narration.enabled), not here.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
