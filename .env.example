# Required for PR analysis + browser capture agent (Claude API calls)
ANTHROPIC_API_KEY=

# Referenced by demo-gen.config.json's auth.envVars for logging into the target app.
# Never commit real values here.
DEMO_USER_EMAIL=
DEMO_USER_PASSWORD=

# Voice-over via ElevenLabs. NARRATION_ENABLED and ELEVENLABS_VOICE_ID override
# demo-gen.config.json, so your voice id / on-switch stay out of the committed config.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
NARRATION_ENABLED=
